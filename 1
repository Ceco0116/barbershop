    <span>Kids Cuts</span><span class="dot">✦</span>
    <span>Premium Grooming</span><span class="dot">✦</span>
  </div>
</div>

<!-- SERVICES -->
<section id="services">
  <p class="section-label">Our Services</p>
  <h2 class="section-title">Crafted for the<br>Modern Gentleman</h2>
  <div class="services-grid">
    <div class="service-card">
      <div class="service-num">01</div>
      <h3 class="service-name">The Classic Cut</h3>
      <p class="service-desc">Precision scissor cut tailored to your face shape, lifestyle, and personal style. Includes shampoo and style finish.</p>
      <div class="service-price">$35 <span>/ 45 min</span></div>
    </div>
    <div class="service-card">
      <div class="service-num">02</div>
      <h3 class="service-name">Royal Shave</h3>
      <p class="service-desc">Traditional straight-razor shave with pre-shave oil, hot lather, and a steamed towel finish. The full ritual.</p>
      <div class="service-price">$45 <span>/ 60 min</span></div>
    </div>
    <div class="service-card">
      <div class="service-num">03</div>
      <h3 class="service-name">Beard Sculpt</h3>
      <p class="service-desc">Shape, define, and tame your beard with precision trimming and conditioning treatment for a polished, intentional look.</p>
      <div class="service-price">$28 <span>/ 30 min</span></div>
    </div>
    <div class="service-card">
      <div class="service-num">04</div>
      <h3 class="service-name">Fade & Taper</h3>
      <p class="service-desc">Expert skin-to-mid fade or classic taper. Clean lines, seamless blending, zero compromise.</p>
      <div class="service-price">$40 <span>/ 50 min</span></div>
    </div>
    <div class="service-card">
      <div class="service-num">05</div>
      <h3 class="service-name">The Full Service</h3>
      <p class="service-desc">Cut + beard sculpt + hot towel treatment. Our signature package for the man who demands the complete experience.</p>
      <div class="service-price">$75 <span>/ 90 min</span></div>
    </div>
    <div class="service-card">
      <div class="service-num">06</div>
      <h3 class="service-name">Junior Cut</h3>
      <p class="service-desc">Patient, precise cuts for boys up to age 12. We make it fun, quick, and something they'll actually look forward to.</p>
      <div class="service-price">$22 <span>/ 30 min</span></div>
    </div>
  </div>
</section>

<!-- ABOUT -->
<section id="about" style="background: rgba(61,51,40,0.2);">
